<% content_for :title, "New Time Attendance" %>

<div class="w-full max-w-[1200px] px-6 py-10">
  <div class="flex justify-start mb-8">
    <div class="relative group">
      <%= link_to employee_path(@employee),
                  class: "neu-button flex items-center justify-center w-[72px] h-[72px]" do %>
        <svg xmlns="http://www.w3.org/2000/svg"
             class="w-5 h-5 rotate-180"
             fill="#8F8F8F"
             viewBox="0 0 24 24">
          <path d="M23.124,9.879,18.538,5.293,17.124,6.707l4.262,4.263L0,11l0,2,21.446-.03-4.323,4.323,1.414,1.414,4.587-4.586A3.007,3.007,0,0,0,23.124,9.879Z"/>
        </svg>
      <% end %>

      <span class="absolute top-1/2 right-22 -translate-y-1/2 whitespace-nowrap rounded-full bg-[#D4C8FF] px-3 py-2 text-[12px] text-white opacity-0 transition group-hover:opacity-100">
        Back to Employee
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16 items-center">
    <div class="w-full">
      <div class="neu-card p-8 md:p-10">
        <div class="mb-8">
          <p class="text-[14px] font-medium tracking-[0.08em] text-[#A0A0A0] uppercase">
            Attendance Setup
          </p>

          <h1 class="mt-2 text-[36px] font-semibold leading-11 text-[#6F6F6F]">
            Create Time Attendance
          </h1>

          <p class="mt-3 text-[16px] leading-7 text-[#A3A3A3]">
            Add a new attendance record to keep employee work hours, check-in, and check-out details organized.
          </p>
        </div>

        <%= render "form", time_attendance: @time_attendance %>
      </div>
    </div>

    <div class="flex h-full items-center">
      <div class="max-w-[460px]">
        <p class="text-[14px] font-medium tracking-[0.08em] text-[#A0A0A0] uppercase">
          Quick Overview
        </p>

        <h2 class="mt-2 text-[32px] font-semibold leading-10 text-[#6F6F6F]">
          Keep daily work records clear
        </h2>

        <p class="mt-4 text-[16px] leading-7.5 text-[#9B9B9B]">
          Create an attendance entry for check-in, check-out, and overtime details in one simple workflow.
        </p>

        <div class="mt-8 space-y-4">
          <div class="neu-info-card">
            <div>
              <p class="text-[16px] font-semibold text-[#7C7C7C]">Track Daily Activity</p>
              <p class="mt-1 text-[14px] leading-6 text-[#A3A3A3]">
                Record employee work dates, attendance hours, and daily activity in one place.
              </p>
            </div>
          </div>

          <div class="neu-info-card">
            <div>
              <p class="text-[16px] font-semibold text-[#7C7C7C]">Support Payroll Accuracy</p>
              <p class="mt-1 text-[14px] leading-6 text-[#A3A3A3]">
                Keep time records ready for salary calculation and overtime review.
              </p>
            </div>
          </div>

          <div class="neu-info-card">
            <div>
              <p class="text-[16px] font-semibold text-[#7C7C7C]">Stay Organized</p>
              <p class="mt-1 text-[14px] leading-6 text-[#A3A3A3]">
                Manage employee attendance with a clean and structured interface.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>