<% content_for :title, "Employee Dashboard" %>

<div class="w-full max-w-[1380px] px-6 py-10">
  <% if notice.present? %>
    <div class="mb-6 rounded-[20px] border border-[#D8F0D2] bg-[#F4FFF1] px-4 py-3">
      <p id="notice" class="text-[14px] font-medium text-green-600">
        <%= notice %>
      </p>
    </div>
  <% end %>

  <div class="mb-8 flex items-start gap-6">
    <div class="relative group shrink-0">
      <%= link_to pages_home_path,
                  class: "neu-button flex h-[72px] w-[72px] items-center justify-center" do %>
        <svg xmlns="http://www.w3.org/2000/svg"x
             class="h-5 w-5 rotate-180"
             fill="#8F8F8F"
             viewBox="0 0 24 24">
          <path d="M23.124,9.879,18.538,5.293,17.124,6.707l4.262,4.263L0,11l0,2,21.446-.03-4.323,4.323,1.414,1.414,4.587-4.586A3.007,3.007,0,0,0,23.124,9.879Z"/>
        </svg>
      <% end %>

      <span class="absolute top-1/2 right-22 -translate-y-1/2 whitespace-nowrap rounded-full bg-[#D4C8FF] px-3 py-2 text-[12px] text-white opacity-0 transition group-hover:opacity-100">
        Back to Home
      </span>
    </div>

    <div class="pt-2">
      <h1 class="text-[34px] font-semibold leading-10.5 text-[#6F6F6F]">
        Welcome to your employee dashboard.
      </h1>
      <p class="mt-2 text-[16px] leading-7 text-[#A3A3A3]">
        Track your attendance and view your payroll details here.
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-8 xl:grid-cols-[420px_minmax(0,1fr)]">
    <div>
      <div class="neu-card px-10 py-9 min-h-[420px]">
        <div class="mb-6 flex items-start justify-between">
          <div>
            <p class="text-[14px] font-semibold uppercase tracking-[0.08em] text-[#A38AFF]">
              <%= @employee.user_name || "EMPLOYEE" %>
            </p>

            <h2 class="mt-3 text-[28px] font-semibold text-[#7A7A7A]">
              <%= @employee.first_name %> <%= @employee.last_name %>
            </h2>
          </div>

          <%= link_to edit_employee_path(@employee),
                      class: "text-[#9B9B9B] transition hover:opacity-80",
                      title: "Edit employee" do %>
            <svg xmlns="http://www.w3.org/2000/svg"
                 class="h-6 w-6"
                 fill="#A8A8A8"
                 viewBox="0 0 24 24">
              <path d="M22.853,1.148a3.626,3.626,0,0,0-5.124,0L1.465,17.412A4.968,4.968,0,0,0,0,20.947V23a1,1,0,0,0,1,1H3.053a4.966,4.966,0,0,0,3.535-1.464L22.853,6.271A3.626,3.626,0,0,0,22.853,1.148ZM5.174,21.122A3.022,3.022,0,0,1,3.053,22H2V20.947a2.98,2.98,0,0,1,.879-2.121L15.222,6.483l2.3,2.3ZM21.438,4.857,18.932,7.364l-2.3-2.295,2.507-2.507a1.623,1.623,0,1,1,2.295,2.3Z"/>
            </svg>
          <% end %>
        </div>

        <div class="space-y-4 text-[17px] leading-7 text-[#9E9E9E]">
          <p>
            Position:
            <span class="font-semibold text-[#7A7A7A]">
              <%= @employee.position.presence || "-" %>
            </span>
          </p>

          <p>
            Salary:
            <span class="font-semibold text-[#7A7A7A]">
              <%= number_with_delimiter(@employee.salary) %>
            </span>
          </p>
        </div>

        <div class="mt-14 space-y-4 text-[17px] leading-7 text-[#9E9E9E]">
          <p>
            All Over time hours:
            <span class="font-semibold text-[#7A7A7A]">
              <%= @employee.time_attendances.sum(:overtime_hours) rescue 0 %>
            </span>
          </p>

          <p>
            Net Pay:
            <span class="font-semibold text-[#7A7A7A]">
              <%= number_with_delimiter(@employee.salary) %>
            </span>
          </p>
        </div>

      </div>
    </div>

    <div>
      <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">

        <div class="ml-auto flex flex-row gap-4 items-end">
          <%= link_to new_employee_time_attendance_path(@employee),
                      class: "neu-pill-success flex h-[52px] w-[160px] items-center justify-center text-[18px] font-[500] text-[#7BC58A]" do %>
            Check in
          <% end %>

          <%= link_to new_employee_time_attendance_path(@employee),
                      class: "neu-pill-waring flex h-[52px] w-[160px] items-center justify-center text-[18px] font-[500] text-[#FFB55A]" do %>
            Check out
          <% end %>
        </div>

      </div>

      <div class="space-y-5 h-90 pr-5 overflow-y-scroll">
        <% if @employee.time_attendances.any? %>
          <% @employee.time_attendances.order(work_date: :desc).each do |time_attendance| %>
            <div class="flex items-center gap-5 ">
              <div class="min-w-0 flex-1">
                <%= render "time_attendances/time_attendance", time_attendance: time_attendance %>
              </div>

              <div class="shrink-0">
                <%= link_to edit_time_attendance_path(time_attendance),
                            class: "neu-button flex h-[72px] w-[72px] items-center justify-center",
                            title: "Edit attendance" do %>
                  <svg xmlns="http://www.w3.org/2000/svg"
                       class="h-5 w-5"
                       fill="#8F8F8F"
                       viewBox="0 0 24 24">
                    <path d="M22.853,1.148a3.626,3.626,0,0,0-5.124,0L1.465,17.412A4.968,4.968,0,0,0,0,20.947V23a1,1,0,0,0,1,1H3.053a4.966,4.966,0,0,0,3.535-1.464L22.853,6.271A3.626,3.626,0,0,0,22.853,1.148ZM5.174,21.122A3.022,3.022,0,0,1,3.053,22H2V20.947a2.98,2.98,0,0,1,.879-2.121L15.222,6.483l2.3,2.3ZM21.438,4.857,18.932,7.364l-2.3-2.295,2.507-2.507a1.623,1.623,0,1,1,2.295,2.3Z"/>
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="neu-empty-state px-8 py-10 text-center">
            <h3 class="text-[24px] font-semibold text-[#7A7A7A]">
              No attendance records yet
            </h3>
            <p class="mt-3 text-[16px] leading-7 text-[#A3A3A3]">
              Start your workday by checking in. Your attendance history will appear here.
            </p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>