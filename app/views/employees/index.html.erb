<% content_for :title, "Employees" %>

<div class="w-full max-w-[1200px] px-6 py-10">
  <div class="mb-8 flex items-center gap-4">
    <div class="relative group shrink-0">
      <%= link_to pages_home_path,
                  class: "neu-button flex h-[72px] w-[72px] items-center justify-center" do %>
        <svg xmlns="http://www.w3.org/2000/svg"
             class="h-5 w-5 rotate-180"
             fill="#8F8F8F"
             viewBox="0 0 24 24">
          <path d="M23.124,9.879,18.538,5.293,17.124,6.707l4.262,4.263L0,11l0,2,21.446-.03-4.323,4.323,1.414,1.414,4.587-4.586A3.007,3.007,0,0,0,23.124,9.879Z"/>
        </svg>
      <% end %>

      <span class="absolute top-1/2 right-22 -translate-y-1/2 whitespace-nowrap rounded-full bg-[#D4C8FF] px-3 py-2 text-[12px] text-white opacity-0 transition group-hover:opacity-100">
        Back to Login
      </span>
    </div>

    <div class="flex-1">
      <p class="text-[14px] font-medium uppercase tracking-[0.08em] text-[#B6AED3]">
        Employee Management
      </p>
      <h1 class="mt-1 text-[32px] font-semibold leading-10 text-[#6F6F6F]">
        Your team, all in one place
      </h1>
      <p class="mt-2 text-[16px] leading-7 text-[#A3A3A3]">
        View, add, and manage employees for attendance and payroll.
      </p>
    </div>

    <% if @employees.any? %>
      <div class="shrink-0">
        <%= link_to new_employee_path,
                    class: "neu-button flex h-[56px] w-[190px] items-center justify-center rounded-full px-6 text-[#8F8F8F]" do %>
          <span class="text-[14px] font-semibold">Create Employee</span>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if notice.present? %>
    <div class="mb-6 rounded-[20px] border border-[#D8F0D2] bg-[#F4FFF1] px-4 py-3">
      <p id="notice" class="text-[14px] font-medium text-green-600">
        <%= notice %>
      </p>
    </div>
  <% end %>

  <% if @employees.any? %>
    <div class="rounded-[28px] border border-[#E4DBFF] bg-[#ECEDF1] p-5 shadow-[10px_10px_20px_rgba(212,213,217,0.28),-10px_-10px_20px_rgba(255,255,255,0.82)]">
      <div class="mb-4 flex items-center justify-between">
        <div>
          <h2 class="text-[20px] font-semibold text-[#6F6F6F]">
            Employee List
          </h2>
          <p class="mt-1 text-[14px] text-[#A3A3A3]">
            Manage employee profiles, attendance access, and salary details.
          </p>
        </div>

        <div class="rounded-full bg-[#F4F1FF] px-4 py-2 text-[13px] font-semibold text-[#9D8FD1]">
          <%= @employees.count %> Employees
        </div>
      </div>

      <div id="employees" class="max-h-[65vh] space-y-4 overflow-y-auto pr-2">
        <% @employees.each do |employee| %>
          <div class="flex flex-col gap-4 rounded-[24px] border border-[#E8E1FF] bg-[#ECEDF1] p-4 lg:flex-row lg:items-center lg:justify-between">
            <div class="min-w-0 flex-1">
              <%= render employee %>
            </div>

            <div class="flex items-center gap-3">
              <%= link_to employee,
                          class: "neu-button flex h-[64px] w-[64px] items-center justify-center",
                          title: "Show" do %>
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="h-5 w-5"
                     fill="#8F8F8F"
                     viewBox="0 0 24 24">
                  <path d="M23.821,11.181v0C22.943,9.261,19.5,3,12,3S1.057,9.261.179,11.181a1.969,1.969,0,0,0,0,1.64C1.057,14.739,4.5,21,12,21s10.943-6.261,11.821-8.181A1.968,1.968,0,0,0,23.821,11.181ZM12,19c-6.307,0-9.25-5.366-10-6.989C2.75,10.366,5.693,5,12,5c6.292,0,9.236,5.343,10,7C21.236,13.657,18.292,19,12,19Z"/>
                  <path d="M12,7a5,5,0,1,0,5,5A5.006,5.006,0,0,0,12,7Zm0,8a3,3,0,1,1,3-3A3,3,0,0,1,12,15Z"/>
                </svg>
              <% end %>

              <%= link_to edit_employee_path(employee),
                          class: "neu-button flex h-[64px] w-[64px] items-center justify-center",
                          title: "Edit" do %>
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="h-5 w-5"
                     fill="#8F8F8F"
                     viewBox="0 0 24 24">
                  <path d="M22.853,1.148a3.626,3.626,0,0,0-5.124,0L1.465,17.412A4.968,4.968,0,0,0,0,20.947V23a1,1,0,0,0,1,1H3.053a4.966,4.966,0,0,0,3.535-1.464L22.853,6.271A3.626,3.626,0,0,0,22.853,1.148ZM5.174,21.122A3.022,3.022,0,0,1,3.053,22H2V20.947a2.98,2.98,0,0,1,.879-2.121L15.222,6.483l2.3,2.3ZM21.438,4.857,18.932,7.364l-2.3-2.295,2.507-2.507a1.623,1.623,0,1,1,2.295,2.3Z"/>
                </svg>
              <% end %>

              <%= button_to employee,
                            method: :delete,
                            class: "neu-button flex h-[64px] w-[64px] items-center justify-center",
                            data: { turbo_confirm: "Are you sure?" },
                            title: "Delete" do %>
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="h-5 w-5"
                     fill="#8F8F8F"
                     viewBox="0 0 24 24">
                  <g>
                    <path d="M22,4H17V2a2,2,0,0,0-2-2H9A2,2,0,0,0,7,2V4H2V6H4V21a3,3,0,0,0,3,3H17a3,3,0,0,0,3-3V6h2ZM9,2h6V4H9Zm9,19a1,1,0,0,1-1,1H7a1,1,0,0,1-1-1V6H18Z"/>
                    <rect x="9" y="10" width="2" height="8"/>
                    <rect x="13" y="10" width="2" height="8"/>
                  </g>
                </svg>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="rounded-[32px] border border-[#E4DBFF] bg-[#ECEDF1] px-8 py-12 text-center shadow-[10px_10px_20px_rgba(212,213,217,0.28),-10px_-10px_20px_rgba(255,255,255,0.82)]">
      <div class="mx-auto flex h-[84px] w-[84px] items-center justify-center rounded-full border border-[#DDD3FF] bg-[#F5F1FF]">
        <svg xmlns="http://www.w3.org/2000/svg"
             class="h-7 w-7"
             fill="#A796E6"
             viewBox="0 0 24 24">
          <g>
            <path d="M9,12A6,6,0,1,0,3,6,6.006,6.006,0,0,0,9,12ZM9,2A4,4,0,1,1,5,6,4,4,0,0,1,9,2Z"/>
            <polygon points="21 10 21 7 19 7 19 10 16 10 16 12 19 12 19 15 21 15 21 12 24 12 24 10 21 10"/>
            <path d="M13.043,14H4.957A4.963,4.963,0,0,0,0,18.957V24H2V18.957A2.96,2.96,0,0,1,4.957,16h8.086A2.96,2.96,0,0,1,16,18.957V24h2V18.957A4.963,4.963,0,0,0,13.043,14Z"/>
          </g>
        </svg>
      </div>

      <h2 class="mt-6 text-[28px] font-semibold text-[#6F6F6F]">
        Your team starts here
      </h2>

      <p class="mt-3 text-[16px] leading-7 text-[#A3A3A3]">
        Add your first employee to begin managing attendance and payroll in one place.
      </p>

      <div class="mt-8 flex justify-center">
        <%= link_to new_employee_path,
                    class: "neu-button flex h-[56px] w-[220px] items-center justify-center rounded-full px-6 text-[#8F8F8F]" do %>
          <span class="text-[14px] font-semibold">Create New Employee</span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>