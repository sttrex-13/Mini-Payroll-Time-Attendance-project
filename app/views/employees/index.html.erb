<% content_for :title, "Employees" %>

<div class="w-full max-w-[1200px] px-6 py-10">
  <div class="flex justify-start mb-8 gap-4">
    <div class="relative group">
      <%= link_to pages_home_path,
                  class: "neu-button flex items-center justify-center w-[72px] h-[72px]" do %>
        <svg xmlns="http://www.w3.org/2000/svg"
             class="w-5 h-5 rotate-180"
             fill="#8F8F8F"
             viewBox="0 0 24 24">
          <path d="M23.124,9.879,18.538,5.293,17.124,6.707l4.262,4.263L0,11l0,2,21.446-.03-4.323,4.323,1.414,1.414,4.587-4.586A3.007,3.007,0,0,0,23.124,9.879Z"/>
        </svg>
      <% end %>

      <span class="absolute top-1/2 right-22 -translate-y-1/2 whitespace-nowrap rounded-full bg-[#D4C8FF] px-3 py-2 text-[12px] text-white opacity-0 transition group-hover:opacity-100">
        Back to Login
      </span>
    </div>

    <div class="grid content-center text-[#B2B2B2] pl-5">
      Manage your team in one place.<br>
      View, add, and manage employees for attendance and payroll.
    </div>
  </div>

  <% if notice.present? %>
    <p id="notice" class="mb-5 inline-block rounded-md bg-green-50 px-3 py-2 font-medium text-green-500">
      <%= notice %>
    </p>
  <% end %>

  <div id="employees" class="space-y-5 h-100 overflow-y-scroll pr-4 pt-2">
    <% if @employees.any? %>
      <% @employees.each do |employee| %>
        <div class="flex flex-row justify-between ">

          <div class="flex-1">
            <%= render employee %>
          </div>

          <div class="flex flex-row items-center gap-3">
            <%= link_to employee,
                        class: "neu-button flex items-center justify-center w-[75px] h-[75px]",
                        title: "Show" do %>
              <svg xmlns="http://www.w3.org/2000/svg"
                   class="w-5 h-5"
                   fill="#8F8F8F"
                   viewBox="0 0 24 24">
                <path d="M23.821,11.181v0C22.943,9.261,19.5,3,12,3S1.057,9.261.179,11.181a1.969,1.969,0,0,0,0,1.64C1.057,14.739,4.5,21,12,21s10.943-6.261,11.821-8.181A1.968,1.968,0,0,0,23.821,11.181ZM12,19c-6.307,0-9.25-5.366-10-6.989C2.75,10.366,5.693,5,12,5c6.292,0,9.236,5.343,10,7C21.236,13.657,18.292,19,12,19Z"/><path d="M12,7a5,5,0,1,0,5,5A5.006,5.006,0,0,0,12,7Zm0,8a3,3,0,1,1,3-3A3,3,0,0,1,12,15Z"/></svg>
          <% end %>

            <%= link_to edit_employee_path(employee),
                        class: "neu-button flex items-center justify-center w-[75px] h-[75px]",
                        title: "Edit" do %>
              <svg xmlns="http://www.w3.org/2000/svg"
                   class="w-5 h-5"
                   fill="#8F8F8F"
                   viewBox="0 0 24 24">
                <path d="M22.853,1.148a3.626,3.626,0,0,0-5.124,0L1.465,17.412A4.968,4.968,0,0,0,0,20.947V23a1,1,0,0,0,1,1H3.053a4.966,4.966,0,0,0,3.535-1.464L22.853,6.271A3.626,3.626,0,0,0,22.853,1.148ZM5.174,21.122A3.022,3.022,0,0,1,3.053,22H2V20.947a2.98,2.98,0,0,1,.879-2.121L15.222,6.483l2.3,2.3ZM21.438,4.857,18.932,7.364l-2.3-2.295,2.507-2.507a1.623,1.623,0,1,1,2.295,2.3Z"/>
              </svg>
            <% end %>

            <%= button_to employee,
                          method: :delete,
                          class: "neu-button flex items-center justify-center w-[75px] h-[75px]",
                          data: { turbo_confirm: "Are you sure?" },
                          title: "Delete" do %>
              <svg xmlns="http://www.w3.org/2000/svg"
                   class="w-5 h-5"
                   fill="#8F8F8F"
                   viewBox="0 0 24 24">
                <g>
                  <path d="M22,4H17V2a2,2,0,0,0-2-2H9A2,2,0,0,0,7,2V4H2V6H4V21a3,3,0,0,0,3,3H17a3,3,0,0,0,3-3V6h2ZM9,2h6V4H9Zm9,19a1,1,0,0,1-1,1H7a1,1,0,0,1-1-1V6H18Z"/>
                  <rect x="9" y="10" width="2" height="8"/>
                  <rect x="13" y="10" width="2" height="8"/>
                </g>
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="flex flex-col justify-center pl-30">
      <p class=" my-4 text-[#B2B2B2]">
        Your team starts here.<br>  Add your first employee to begin.
      </p>

        <%= link_to new_employee_path, class: "neu-button flex items-center justify-center  w-[250px] h-[50px]" do %>
          <p class="text-center text-[#B2B2B2]">
            Create New Employee
          </p>
        <% end %>

    <% end %>
    </div>
  </div>
</div>