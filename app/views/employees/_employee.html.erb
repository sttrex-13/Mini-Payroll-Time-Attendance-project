<div id="<%= dom_id employee %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1s">User name:</strong>
    <%= employee.user_name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">First name:</strong>
    <%= employee.first_name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Last name:</strong>
    <%= employee.last_name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Salary:</strong>
    <%= employee.salary %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Position:</strong>
    <%= employee.position %>
  </div>
</div>