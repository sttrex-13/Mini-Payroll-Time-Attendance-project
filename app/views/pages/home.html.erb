<div>
  <h1>Home page</h1>

  <%= form_with url: login_path, method: :post do |form| %>
    <p>Username</p>
    <%= form.text_field :username, class: "block shadow-sm rounded-md border px-3 py-2 mt-2 w-full" %>

    <% if flash[:alert] %>
      <p class="text-red-500 mt-2"><%= flash[:alert] %></p>
    <% end %>

    <%= form.submit "Login", class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium mt-3" %>
  <% end %>

  <%= link_to "New employee", new_employee_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium mt-3" %>
</div>